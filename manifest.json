{
  "manifest_version": 3,
  "name": "Tab Group Workspaces",
  "version": "1.0.0",
  "description": "Organize your tabs into workspaces — each with its own tab groups, pinned tabs, and sidebar. Switch windows, stay focused.",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "https://api.lemonsqueezy.com/"
  ],
"icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab Groups"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "open_tab_groups_sidebar": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Open Tab Groups Sidebar"
    }
  }
}

