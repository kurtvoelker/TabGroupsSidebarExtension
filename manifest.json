{
  "manifest_version": 3,
  "name": "Tab Groups Sidebar",
  "version": "0.1.0",
  "description": "Sidebar to list and manage Chrome Tab Groups (pinned tabs first, color-coded, searchable tabs).",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "sidePanel"
  ],
"icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab Groups"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "open_tab_groups_sidebar": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Open Tab Groups Sidebar"
    }
  }
}

